---
import Base from '../layouts/Base.astro';
import { profile, socials, experience, projects, publications } from '../data/site';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
---

<Base>
  <!-- Hero -->
  <header class="hero" id="about">
    {profile.photo && <img class="hero-photo" src={profile.photo} alt={profile.name} />}
    <div>
      <h1>{profile.name}</h1>
      <p class="tagline">{profile.tagline}</p>
      <div class="socials">
        {socials.map((s) => <a href={s.href} target="_blank" rel="noopener">{s.label}</a>)}
        {profile.resume && <a href={profile.resume} target="_blank" rel="noopener">Resume</a>}
        {profile.email && <a href={`mailto:${profile.email}`}>Email</a>}
      </div>
    </div>
  </header>

  <!-- About -->
  <section>
    <h2 class="section-title">about</h2>
    <p class="about-text">{profile.about}</p>
  </section>

  <!-- Experience -->
  <section id="work">
    <h2 class="section-title">work &amp; education</h2>
    <div class="timeline">
      {experience.map((e) => (
        <div class="tl-item">
          <div class="tl-period">{e.period}</div>
          <div>
            <span class="tl-role">{e.role}</span>
            {' · '}
            {e.orgUrl ? (
              <a class="tl-org" href={e.orgUrl} target="_blank" rel="noopener">{e.org}</a>
            ) : (
              <span class="tl-org">{e.org}</span>
            )}
          </div>
          <p class="tl-blurb">{e.blurb}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Projects -->
  <section id="projects">
    <h2 class="section-title">projects</h2>
    <div class="grid">
      {projects.map((p) => (
        <a class="card" href={p.href} target="_blank" rel="noopener">
          <div class="card-name">{p.name}</div>
          <p class="card-blurb">{p.blurb}</p>
          <div class="tags">{p.tags.map((t) => <span class="tag">{t}</span>)}</div>
        </a>
      ))}
    </div>
  </section>

  <!-- Writing -->
  {posts.length > 0 && (
    <section id="writing">
      <h2 class="section-title">writing</h2>
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-item">
            <div class="post-date">{fmt(post.data.date)}</div>
            <h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
          </li>
        ))}
      </ul>
      <p style="margin-top:18px"><a href="/blog">all posts →</a></p>
    </section>
  )}

  <!-- Publications -->
  {publications.length > 0 && (
    <section id="publications">
      <h2 class="section-title">publications</h2>
      {publications.map((pub) => (
        <div class="pub">
          <div class="pub-title">
            {pub.href ? <a href={pub.href} target="_blank" rel="noopener">{pub.title}</a> : pub.title}
          </div>
          <div class="pub-venue">{pub.venue}</div>
          <div class="pub-authors">{pub.authors}</div>
        </div>
      ))}
    </section>
  )}
</Base>
