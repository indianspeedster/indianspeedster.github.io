---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Base title="Blog · Shekhar Pandey" description="Notes on ML systems, GPU kernels, and training.">
  <section style="padding-top:48px">
    <h2 class="section-title">writing</h2>
    {posts.length === 0 ? (
      <p class="about-text">No posts yet — check back soon.</p>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li class="post-item">
            <div class="post-date">{fmt(post.data.date)}</div>
            <h3><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
            <p>{post.data.description}</p>
          </li>
        ))}
      </ul>
    )}
  </section>
</Base>
